#!/bin/bash

set -u

SCRIPT_PATH="${BASH_SOURCE[0]}"

PARALLEL=""
PARALLEL_COUNT=""
SINCE=""
INTERACTIVE=false
VERBOSE=false
PERSIST_LOGS=false
DRY_RUN=false
LOG_BASE=""
LOG_DIR=""
STATUS_DIR=""
REPOS=""
HAS_FD=false
HAS_FZF=false
REPO_LIST=()
PROGRESS_COMPLETED=0

show_help() {
  local version
  version=$(print_version | awk '{print $2}')

  cat << 'EOF'

        _ _              _ _             
   __ _(_) |_       __ _| (_) __ _ _ __  
  / _` | | __|____ / _` | | |/ _` | '_ \ 
 | (_| | | ||_____| (_| | | | (_| | | | |
  \__, |_|\__|     \__,_|_|_|\__, |_| |_|
  |___/                      |___/       

EOF

  cat << EOF
git-align v$version

» Keep multiple git repositories aligned

USAGE:
  git-align [options]

OPTIONS:
  -p, --parallel <n>     Run in parallel with n jobs
  -s, --since <time>     Only update repos with remote changes since given time
  -i, --interactive      Select repositories interactively (fzf)
  -v, --verbose          Show live output during execution
      --logs             Persist logs (otherwise only failures are kept)
      --dry-run          Show planned actions without changing repositories
  -V, --version          Show version
  -h, --help             Show this help message
EOF
}

get_script_dir() {
  cd "$(dirname "$SCRIPT_PATH")" && pwd
}

get_repo_root() {
  cd "$(dirname "$SCRIPT_PATH")/.." && pwd
}

print_version() {
  local script_dir
  local repo_root
  local version

  script_dir=$(get_script_dir)
  repo_root=$(get_repo_root)

  if [ -f "$script_dir/git-align.version" ]; then
    version=$(head -n 1 "$script_dir/git-align.version")
  elif [ -f "$repo_root/VERSION" ]; then
    version=$(head -n 1 "$repo_root/VERSION")
  elif git -C "$repo_root" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    version=$(git -C "$repo_root" describe --tags --abbrev=0 2>/dev/null | sed 's/^v//')
  fi

  if [ -z "${version:-}" ]; then
    version="dev"
  fi

  echo "git-align $version"
}

read_command_lines() {
  local target_name="$1"
  shift
  local line

  eval "$target_name=()"
  while IFS= read -r line; do
    eval "$target_name+=(\"\$line\")"
  done < <("$@")
}

die() {
  echo "❌ $1" >&2
  exit 1
}

reset_state() {
  PARALLEL=""
  PARALLEL_COUNT=""
  SINCE=""
  INTERACTIVE=false
  VERBOSE=false
  PERSIST_LOGS=false
  DRY_RUN=false
  LOG_BASE="${GIT_ALIGN_LOG_DIR:-$HOME/.git-align/logs}"
  LOG_DIR=""
  STATUS_DIR=""
  REPOS=""
  HAS_FD=false
  HAS_FZF=false
  REPO_LIST=()
  PROGRESS_COMPLETED=0
}

require_arg() {
  local option="$1"
  local value="${2-}"

  if [ -z "$value" ] || [[ "$value" == -* ]]; then
    die "Option $option requires a value"
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --parallel=*)
        PARALLEL_COUNT="${1#--parallel=}"
        PARALLEL="-P$PARALLEL_COUNT"
        shift
        ;;
      -p|--parallel)
        require_arg "$1" "${2-}"
        PARALLEL_COUNT="$2"
        PARALLEL="-P$PARALLEL_COUNT"
        shift 2
        ;;
      --since=*)
        SINCE="${1#--since=}"
        shift
        ;;
      -s|--since)
        require_arg "$1" "${2-}"
        SINCE="$2"
        shift 2
        ;;
      -i|--interactive)
        INTERACTIVE=true
        shift
        ;;
      -v|--verbose)
        VERBOSE=true
        shift
        ;;
      --logs)
        PERSIST_LOGS=true
        shift
        ;;
      --dry-run)
        DRY_RUN=true
        shift
        ;;
      -h|--help)
        show_help
        exit 0
        ;;
      -V|--version)
        print_version
        exit 0
        ;;
      *)
        echo "❌ Unknown option: $1"
        echo "Use --help for usage"
        exit 1
        ;;
    esac
  done
}

detect_tools() {
  command -v fd >/dev/null 2>&1 && HAS_FD=true
  command -v fzf >/dev/null 2>&1 && HAS_FZF=true
}

init_log_dir() {
  if [ "$PERSIST_LOGS" = true ]; then
    local timestamp
    timestamp=$(date +"%Y-%m-%d_%H-%M-%S")
    LOG_DIR="$LOG_BASE/$timestamp"
    mkdir -p "$LOG_DIR"
  else
    LOG_DIR=$(mktemp -d -t git-align-logs-XXXX)
  fi

  STATUS_DIR="$LOG_DIR/status"
  mkdir -p "$STATUS_DIR"

  export LOG_DIR STATUS_DIR SINCE DRY_RUN
}

print_run_header() {
  echo "🔄 Updating repositories..."
  [ -n "$PARALLEL_COUNT" ] && echo "⚡ Parallel: $PARALLEL_COUNT"
  [ -n "$SINCE" ] && echo "⏱️ Since: $SINCE"
  [ "$INTERACTIVE" = true ] && echo "🎯 Interactive mode"
  [ "$DRY_RUN" = true ] && echo "🧪 Dry run mode"
  echo "📂 Logs: $LOG_DIR"
  echo ""
}

process_repo() {
  local repo_index="$1"
  local repo_path="$2"
  local log_file="$LOG_DIR/$(printf '%04d' "$repo_index").log"
  local repo_file="$STATUS_DIR/$(printf '%04d' "$repo_index").repo"
  local status_file="$STATUS_DIR/$(printf '%04d' "$repo_index").status"
  local exit_code=0
  printf '%s\n' "$repo_path" > "$repo_file"
  printf 'running\n' > "$status_file"

  (
    set -e

    cd "$repo_path" || exit 1

    local current
    local default_branch
    local changes
    local stashed=false
    local has_untracked=false

    echo "📦 $repo_path"

    if [ "$DRY_RUN" = true ]; then
      echo "📝 Would fetch --all --prune"
    else
      git fetch --all --prune
    fi

    current=$(git branch --show-current)
    default_branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed "s@^refs/remotes/origin/@@")

    if [ -z "$default_branch" ]; then
      echo "⚠️ No default branch"
      exit 1
    fi

    echo "👉 Current: $current | Default: $default_branch"

    if git diff --quiet HEAD "origin/$default_branch"; then
      echo "⏭️ Already up-to-date"
      echo "✅ SUCCESS"
      exit 0
    fi

    if [ -n "$SINCE" ]; then
      changes=$(git log HEAD.."origin/$default_branch" --since="$SINCE" --oneline)

      if [ -z "$changes" ]; then
        echo "⏭️ No recent changes"
        echo "✅ SUCCESS"
        exit 0
      fi
    fi

    if [ -n "$(git ls-files --others --exclude-standard)" ]; then
      has_untracked=true
    fi

    if ! git diff --quiet || ! git diff --cached --quiet || [ "$has_untracked" = true ]; then
      if [ "$DRY_RUN" = true ]; then
        echo "📝 Would stash local changes"
      else
        echo "👉 Stashing changes"
        git stash push -u -m auto-update
        stashed=true
      fi
    fi

    if [ "$DRY_RUN" = true ]; then
      echo "📝 Would switch to $default_branch"
      echo "📝 Would pull --rebase origin $default_branch"

      if [ "$current" != "$default_branch" ]; then
        echo "📝 Would switch back to $current"
        echo "📝 Would rebase $current onto origin/$default_branch"
      fi

      if ! git diff --quiet || ! git diff --cached --quiet || [ "$has_untracked" = true ]; then
        echo "📝 Would restore stashed changes"
      fi

      echo "✅ SUCCESS"
      exit 0
    fi

    git switch "$default_branch"
    git pull --rebase origin "$default_branch"

    if [ "$current" != "$default_branch" ]; then
      git switch "$current"
      git rebase "origin/$default_branch"
    fi

    if [ "$stashed" = true ]; then
      if ! git stash pop; then
        echo "⚠️ Stash conflict"
        exit 1
      fi
    fi

    git status -sb

    echo "✅ SUCCESS"
  ) > "$log_file" 2>&1

  exit_code=$?

  if [ "$exit_code" -eq 0 ]; then
    printf 'success\n' > "$status_file"
  else
    printf 'failed\n' > "$status_file"
  fi

  return "$exit_code"
}

discover_repos() {
  local excludes="node_modules|vendor|target|dist|build|.terraform|.gradle|.venv|__pycache__|.next|out|coverage"

  if [ "$HAS_FD" = true ]; then
    read_command_lines REPO_LIST bash -c 'fd -H -t d ".git" -x dirname | sort -u | grep -vE "/('"$excludes"')/"'
  else
    echo "⚠️ 'fd' not found, falling back to slower 'find'"
    read_command_lines REPO_LIST bash -c 'find . -type d -name ".git" -exec dirname {} \; | sort -u | grep -vE "/('"$excludes"')/"'
  fi
}

select_repos() {
  if [ "$INTERACTIVE" = true ]; then
    if [ "$HAS_FZF" = true ]; then
      read_command_lines REPO_LIST bash -c 'printf "%s\n" "$@" | fzf -m --preview '\''git -C {} status -sb'\''' _ "${REPO_LIST[@]}"
    else
      echo "⚠️ 'fzf' not found, skipping interactive mode"
    fi
  fi
}

progress_bar() {
  local done="$1"
  local total="$2"
  local width=20
  local filled=0
  local empty=0
  local bar

  if [ "$total" -gt 0 ]; then
    filled=$((done * width / total))
  fi
  empty=$((width - filled))

  bar=$(printf '%*s' "$filled" '' | tr ' ' '#')
  bar="${bar}$(printf '%*s' "$empty" '' | tr ' ' '-')"
  printf '[%s] %s/%s' "$bar" "$done" "$total"
}

print_repo_progress() {
  local done="$1"
  local total="$2"
  local status="$3"
  local repo_path="$4"

  printf '%s %s %s\n' "$(progress_bar "$done" "$total")" "$status" "$repo_path"
}

emit_finished_progress() {
  local total="$1"
  local status_file
  local repo_key
  local repo_path
  local repo_status
  local marker
  local emitted=false

  for status_file in "$STATUS_DIR"/*.status; do
    [ -f "$status_file" ] || continue
    repo_status=$(cat "$status_file")

    if [ "$repo_status" = "running" ]; then
      continue
    fi

    marker="${status_file}.printed"
    if [ -f "$marker" ]; then
      continue
    fi

    : > "$marker"
    repo_key=$(basename "$status_file" .status)
    repo_path=$(cat "$STATUS_DIR/$repo_key.repo")
    PROGRESS_COMPLETED=$((PROGRESS_COMPLETED + 1))

    if [ "$repo_status" = "success" ]; then
      print_repo_progress "$PROGRESS_COMPLETED" "$total" "✅" "$repo_path"
    else
      print_repo_progress "$PROGRESS_COMPLETED" "$total" "❌" "$repo_path"
    fi

    emitted=true
  done

  if [ "$emitted" = true ]; then
    return 0
  fi

  return 1
}

run_repos() {
  local total="${#REPO_LIST[@]}"
  local repo
  local repo_index
  local runner_pid
  PROGRESS_COMPLETED=0

  echo "📦 Selected $total repositories"

  if [ "$total" -eq 0 ]; then
    return 0
  fi

  if [ -z "$PARALLEL" ]; then
    for repo_index in "${!REPO_LIST[@]}"; do
      repo="${REPO_LIST[$repo_index]}"
      process_repo "$repo_index" "$repo" || true
      emit_finished_progress "$total" || true
    done
    return 0
  fi

  export -f process_repo
  for repo_index in "${!REPO_LIST[@]}"; do
    printf '%s\0%s\0' "$repo_index" "${REPO_LIST[$repo_index]}"
  done | xargs -0 -n2 -P "$PARALLEL_COUNT" bash -c 'process_repo "$1" "$2" || true' _ &
  runner_pid=$!

  while kill -0 "$runner_pid" 2>/dev/null; do
    if ! emit_finished_progress "$total"; then
      sleep 0.1
    fi
  done

  wait "$runner_pid" || true
  emit_finished_progress "$total" || true
}

print_logs() {
  local -a log_files=()

  if [ "$VERBOSE" = true ]; then
    echo ""
    echo "📜 Detailed logs"
    echo "-----------------------------------"
  fi

  if [ "$HAS_FD" = true ]; then
    read_command_lines log_files bash -c 'fd -t f -e log . "$1" | sort' _ "$LOG_DIR"
  else
    read_command_lines log_files bash -c 'find "$1" -type f -name "*.log" | sort' _ "$LOG_DIR"
  fi

  for log in "${log_files[@]}"; do
    local repo
    repo=$(cat "$STATUS_DIR/$(basename "$log" .log).repo")

    if [ "$VERBOSE" = true ]; then
      echo ""
      echo "=============================="
      echo "📦 $repo"
      echo "=============================="
      cat "$log"
    fi
  done
}

print_summary() {
  local success
  local failed
  local -a failed_logs=()
  local log

  echo ""
  echo "📊 Summary"
  echo "-----------------------------------"

  success=$(grep -l "✅ SUCCESS" "$LOG_DIR"/*.log 2>/dev/null | wc -l | tr -d " ")
  failed=$(grep -L "✅ SUCCESS" "$LOG_DIR"/*.log 2>/dev/null | wc -l | tr -d " ")

  echo "✅ Success: $success"
  echo "❌ Failed : $failed"

  if [ "$failed" -gt 0 ]; then
    read_command_lines failed_logs bash -c 'grep -L "✅ SUCCESS" "$@" 2>/dev/null' _ "$LOG_DIR"/*.log
    echo ""
    echo "⚠️ Failed repositories:"

    for log in "${failed_logs[@]}"; do
      local repo
      repo=$(basename "$log" .log | sed "s|_|/|g")
      echo "❌ $repo"
      echo "   → $log"
    done

    echo ""
  fi

  if [ "$PERSIST_LOGS" = false ]; then
    if [ "$failed" -eq 0 ]; then
      rm -rf "$LOG_DIR"
    else
      for log in "$LOG_DIR"/*.log; do
        if grep -q "✅ SUCCESS" "$log"; then
          rm -f "$log"
        fi
      done
      echo "📂 Logs: $LOG_DIR (failures only)"
    fi
  else
    echo "📂 Logs: $LOG_DIR"
  fi

  echo "-----------------------------------"
  echo "🎉 Done!"

  if [ "$failed" -gt 0 ]; then
    return 1
  fi

  return 0
}

main() {
  reset_state
  parse_args "$@"
  detect_tools
  init_log_dir
  print_run_header
  discover_repos
  select_repos
  run_repos
  print_logs
  print_summary
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
